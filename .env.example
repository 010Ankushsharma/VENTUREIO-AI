# ============================================================
# VentureIQ AI — Environment Variables
# ============================================================

# ---- General ----
APP_ENV=development
APP_NAME=VentureIQ AI
SECRET_KEY=your-secret-key-here
DEBUG=true

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://ventureiq:password@db:5432/ventureiq
REDIS_URL=redis://redis:6379/0

# ---- AI / LLM ----
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# ---- Vector DB ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=ventureiq_docs

# ---- Storage ----
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_S3_BUCKET=ventureiq-documents
AWS_REGION=us-east-1

# ---- Auth ----
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=VentureIQ AI
